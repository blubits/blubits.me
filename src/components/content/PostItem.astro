---
interface Props {
  href: string;
  title: string;
}

const { href, title } = Astro.props;
---
<a
  class:list={[
    "block w-full",
    "grid grid-cols-2 gap-x-4 gap-y-3 md:grid-cols-6 lg:grid-cols-7",
    "rounded-2xl border border-transparent",
    "bg-transparent",
    "px-6 py-6",
    "transition-[background-color,border-color,box-shadow,backdrop-filter] duration-300 ease-out",
    "hover:bg-white/10 dark:hover:bg-white/10",
    "hover:border-white/20 dark:hover:border-white/20",
    "hover:backdrop-blur-md hover:backdrop-saturate-150",
    "hover:shadow-[0_0_0_1px_rgba(255,255,255,0.14),0_18px_42px_rgba(59,130,246,0.12)]",
    "cursor-pointer",
  ]}
  href={href}
  ontouchstart=""
>
  <div class="col-span-4 md:col-span-6 lg:col-span-1">
    <slot name="details-left" />
  </div>
  <div class="col-span-2 space-y-1 md:col-span-4">
    <slot name="image" />
    <h2 class="text-xl font-semibold">{title}</h2>
    <slot name="description" />
  </div>
  <div class="col-span-4 md:col-span-2">
    <slot name="details-right" />
  </div>
</a>
