---
import { CARD_DIMENSIONS } from '@/constants/ui';

export interface Props {
  title: string;
  description: string;
  href?: string;
  theme?: 'default' | 'disabled';
  customHeight?: string;
}

const {
  title,
  description,
  href,
  theme = 'default',
  customHeight,
} = Astro.props;

const themeClasses = {
  default: 'text-black dark:text-white',
  disabled: 'border border-transparent text-black dark:text-white opacity-50 cursor-not-allowed',
};

const height = customHeight || CARD_DIMENSIONS.height;
---

<a
  class:list={[
    "relative flex flex-col gap-4 rounded-2xl",
    height,
    "py-6 px-6",
    theme === 'default' && [
      "z-20 hover:z-30",
      "bg-transparent border border-transparent",
      "transition-[background-color,border-color,box-shadow,backdrop-filter] duration-300 ease-out",
      "hover:bg-white/10 dark:hover:bg-white/10",
      "hover:border-white/20 dark:hover:border-white/20",
      "hover:backdrop-blur-md hover:backdrop-saturate-150",
      "hover:shadow-[0_0_0_1px_rgba(255,255,255,0.14),0_18px_42px_rgba(59,130,246,0.12)]",
      "focus-visible:bg-white/10 dark:focus-visible:bg-white/10",
      "focus-visible:border-white/20 dark:focus-visible:border-white/20",
      "focus-visible:backdrop-blur-md focus-visible:backdrop-saturate-150",
      "focus-visible:shadow-[0_0_0_1px_rgba(255,255,255,0.14),0_18px_42px_rgba(59,130,246,0.12)]",
      "cursor-pointer",
    ],
    theme === 'disabled' && [
      "z-20",
      "rounded-2xl",
    ],
    themeClasses[theme],
  ]}
  href={href}
  ontouchstart=""
>
  <div class:list={[CARD_DIMENSIONS.thumbnailHeight, CARD_DIMENSIONS.width, "object-cover"]}>
    <slot name="thumbnail" />
  </div>
  <div class:list={["flex flex-col gap-2", CARD_DIMENSIONS.width]}>
    <div class="flex items-center gap-2">
      <h2 class="text-xl font-semibold">{title}</h2>
      <slot name="tag" />
    </div>
    <p class="text-md">{description}</p>
  </div>
</a>
